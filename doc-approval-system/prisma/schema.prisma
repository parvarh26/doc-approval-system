generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  REVIEWER
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum Action {
  UPLOAD
  APPROVE
  REJECT
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  role      Role       @default(USER)
  documents Document[] @relation("UploaderDocuments")
  auditLogs AuditLog[] @relation("UserAuditLogs")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Document {
  id           String     @id @default(uuid())
  title        String
  filename     String
  originalPath String
  stampedPath  String?
  status       Status     @default(PENDING)
  uploadedBy   User       @relation("UploaderDocuments", fields: [uploadedById], references: [id])
  uploadedById String
  auditLogs    AuditLog[] @relation("DocumentAuditLogs")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  action     Action
  document   Document @relation("DocumentAuditLogs", fields: [documentId], references: [id])
  documentId String
  user       User     @relation("UserAuditLogs", fields: [userId], references: [id])
  userId     String
  timestamp  DateTime @default(now())
}
